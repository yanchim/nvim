{
  "class": {
    "prefix": "class",
    "body": ["class ${1:$TM_FILENAME_BASE} {", "\t$0", "}"],
    "description": "Snippet for class declaration"
  },
  "init": {
    "prefix": "init",
    "body": ["init {", "\t$0", "}"],
    "description": "Snippet for init block"
  },
  "finally": {
    "prefix": "finally",
    "body": ["finally {", "\t$1", "}"],
    "description": "Snippet for finally block"
  },
  "constructor": {
    "prefix": "constructor",
    "body": ["constructor($1) {", "\t$0", "}"],
    "description": "Snippet for constructor function"
  },
  "function declaration": {
    "prefix": "fun",
    "body": ["fun ${1:name}($2) {", "\t$0", "}"],
    "description": "Snippet for function declaration"
  },
  "if": {
    "prefix": "if",
    "body": "if (${1:cond}) ${2:value}",
    "description": "Snippet for if expression"
  },
  "when": {
    "prefix": "when",
    "body": [
      "when (${1:value}) {",
      "\t${2:branch} -> ${3:branchValue}",
      "\telse -> ${4:defaultValue}",
      "}"
    ],
    "description": "Snippet for when expression"
  },
  "while": {
    "prefix": "while",
    "body": ["while (${1:cond}) {", "\t$0", "}"],
    "description": "Snippet for while expression"
  },
  "do...while": {
    "prefix": "dowhile",
    "body": ["do {", "\t$1", "} while (${2:cond})"],
    "description": "Snippet for do...while expression"
  },
  "for": {
    "prefix": "for",
    "body": ["for ($1) {", "\t$0", "}"],
    "description": "Snippet for for loop"
  },
  "try...catch": {
    "prefix": "trycatch",
    "body": ["try {", "\t$1", "} catch (e: Exception) {", "\t$2", "} finally {", "\t$3", "}"],
    "description": "Snippet for try block"
  },
  "documentation": {
    "prefix": "doc",
    "body": ["/**", " * $0", " */"],
    "description": "Documentation"
  }
}
