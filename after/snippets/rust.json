{
  "allow": {
    "prefix": "allow",
    "body": ["#![allow($1)]"],
    "description": "#![allow(...)]"
  },
  "cfg": {
    "prefix": "cfg",
    "body": ["#[cfg($1)]"],
    "description": "#[cfg(...)]"
  },
  "cfg_attr": {
    "prefix": "cfgattr",
    "body": ["#[cfg_attr($1, $2)]"],
    "description": "#[cfg_attr(..., ...)]"
  },
  "deny": {
    "prefix": "deny",
    "body": ["#![deny($1)]"],
    "description": "#![deny(...)]"
  },
  "derive": {
    "prefix": "derive",
    "body": ["#[derive($1)]"],
    "description": "#[derive(...)]"
  },
  "feature": {
    "prefix": "feature",
    "body": ["#![feature($1)]"],
    "description": "#![feature(...)]"
  },
  "macro_use": {
    "prefix": "macrouse",
    "body": ["#[macro_use($1)]"],
    "description": "#[macro_use(...)]"
  },
  "no_core": {
    "prefix": "nocore",
    "body": ["#![no_core]"],
    "description": "#![no_core]"
  },
  "no_std": {
    "prefix": "nostd",
    "body": ["#![no_std]"],
    "description": "#![no_std]"
  },
  "repr": {
    "prefix": "repr",
    "body": ["#[repr($1)]"],
    "description": "#[repr(...)]"
  },
  "warn": {
    "prefix": "warn",
    "body": ["#![warn($1)]"],
    "description": "#![warn(...)]"
  },
  "assert": {
    "prefix": "assert",
    "body": ["assert!($1);"],
    "description": "assert!(...);"
  },
  "assert_eq": {
    "prefix": "asserteq",
    "body": ["assert_eq!($1, $2);"],
    "description": "assert_eq!(..., ...);"
  },
  "assert_ne": {
    "prefix": "assertne",
    "body": ["assert_ne!($1, $2);"],
    "description": "assert_ne!(..., ...);"
  },
  "dbg": {
    "prefix": "dbg",
    "body": ["dbg!($1)"],
    "description": "dbg"
  },
  "eprint": {
    "prefix": "eprint",
    "body": ["eprint!($1)"],
    "description": "eprint!(...);"
  },
  "eprintln": {
    "prefix": "eprintln",
    "body": ["eprintln!($1)"],
    "description": "eprintln!(...);"
  },
  "format": {
    "prefix": "format",
    "body": ["format!(\"$1\")"],
    "description": "format!(...);"
  },
  "panic": {
    "prefix": "panic",
    "body": ["panic!($1)"],
    "description": "panic!(...);"
  },
  "print": {
    "prefix": "print",
    "body": ["print!($1)"],
    "description": "print!(...);"
  },
  "println": {
    "prefix": "println",
    "body": ["println!($1)"],
    "description": "println!(...);"
  },
  "todo": {
    "prefix": "todo",
    "body": ["todo!($1)"],
    "description": "todo!(...);"
  },
  "unimplemented": {
    "prefix": "unimplemented",
    "body": ["unimplemented!($1)"],
    "description": "unimplemented!(...);"
  },
  "unreachable": {
    "prefix": "unreachable",
    "body": ["unreachable!($1)"],
    "description": "unreachable!(...);"
  },
  "vec": {
    "prefix": "vec",
    "body": ["vec![$1]"],
    "description": "vec!(...);"
  },
  "enum": {
    "prefix": "enum",
    "body": ["enum ${1:Name} {", "\t$0,", "}"],
    "description": "enum ... { ... }"
  },
  "fn": {
    "prefix": "fn",
    "body": ["fn ${1:name}($2) {", "\t${0:todo!();}", "}"],
    "description": "fn ...(...) { ... }"
  },
  "for": {
    "prefix": "for",
    "body": ["for ${1:elem} in ${2:iter} {", "\t${0:todo!();}", "}"],
    "description": "for ... in ... { ... }"
  },
  "if-let": {
    "prefix": "iflet",
    "body": ["if let ${1:Some(pat)} = ${2:expr} {", "\t${0:todo!();}", "}"],
    "description": "if let ... = ... { ... }"
  },
  "if": {
    "prefix": "if",
    "body": ["if ${1:condition} {", "\t${0:todo!();}", "}"],
    "description": "if ... { ... }"
  },
  "impl": {
    "prefix": "impl",
    "body": ["impl $1 {", "\t${0:// add code here}", "}"],
    "description": "impl ... { ... }"
  },
  "impl-for": {
    "prefix": "implfor",
    "body": ["impl ${1:Trait} for ${2:Type} {", "\t${0:// add code here}", "}"],
    "description": "impl ... for ... { ... }"
  },
  "loop": {
    "prefix": "loop",
    "body": ["loop $1 {", "\t$0", "}"],
    "description": "loop"
  },
  "macro_rules": {
    "prefix": "macro",
    "body": ["macro_rules! ${1:name} {", "\t(${2}) => (${3})", "}"],
    "description": "macro_rules! ... { ... }"
  },
  "main": {
    "prefix": "main",
    "body": ["fn main() {", "\t${0:todo!();}", "}"],
    "description": "fn main() { ... }"
  },
  "match": {
    "prefix": "match",
    "body": ["match ${1:expr} {", "\t$0", "}"],
    "description": "match ... { ... }"
  },
  "mod": {
    "prefix": "mod",
    "body": ["mod ${1:name} {", "\t${0:// add code here}", "}"],
    "description": "mod ... { ... }"
  },
  "modtest": {
    "prefix": "modtest",
    "body": [
      "#[cfg(test)]",
      "mod tests {",
      "\tuse super::*;",
      "",
      "\t#[test]",
      "\tfn ${1:name}() {",
      "\t\t${2:todo!();}",
      "\t}",
      "}"
    ],
    "description": "#[cfg(test)]\nmod test {...}"
  },
  "struct": {
    "prefix": "struct",
    "body": ["struct ${1:Name} {", "\t$0,", "}"],
    "description": "struct ... { ... }"
  },
  "test": {
    "prefix": "test",
    "body": ["#[test]", "fn ${1:name}() {", "\t${0:todo!();}", "}"],
    "description": "#[test]"
  },
  "trait": {
    "prefix": "trait",
    "body": ["trait ${1:Name} {", "\t${0:// add code here}", "}", ""],
    "description": "trait ... { ... }"
  },
  "union": {
    "prefix": "union",
    "body": ["union ${1:Name} {", "\t${0:// add code here}", "}", ""],
    "description": "union ... { ... }"
  },
  "while-let": {
    "prefix": "whilelet",
    "body": ["while let ${1:Some(pat)} = ${2:expr} {", "\t${0:todo!();}", "}"],
    "description": "while let ... = ... { ... }"
  },
  "while": {
    "prefix": "while",
    "body": ["while ${1:condition} {", "\t${0:todo!();}", "}"],
    "description": "while ... { ... }"
  }
}
