{
  "#!/usr/bin/env python": {
    "prefix": "shebang",
    "body": "#!/usr/bin/env python$0",
    "description": "Shebang line for the first python in PATH"
  },
  "if __name__ == __main__": {
    "prefix": "ifmain",
    "body": ["if __name__ == \"__main__\":", "\t${1:main()}"],
    "description": "Execute code if the file is executed directly"
  },
  "if": {
    "prefix": "if",
    "body": ["if ${1:cond}:", "\t${2:pass}"],
    "description": "if statement"
  },
  "match/case": {
    "prefix": "match",
    "body": ["match ${1:expr}:", "\tcase ${2:pattern}:", "\t\t${3:pass}"],
    "description": "match/case statements"
  },
  "case": {
    "prefix": "case",
    "body": ["case ${2:pattern}:", "\t${3:pass}"],
    "description": "case block"
  },
  "while": {
    "prefix": "while",
    "body": ["while ${1:cond}:", "\t${2:pass}"],
    "description": "while loop"
  },
  "for": {
    "prefix": "for",
    "body": ["for ${1:value} in ${2:iterable}:", "\t${3:pass}"],
    "description": "for loop"
  },
  "with": {
    "prefix": "with",
    "body": ["with ${1:expr} as ${2:target}:", "\t${3:pass}"],
    "description": "'with' statement"
  },
  "lambda": {
    "prefix": "lambda",
    "body": ["lambda ${1:args}: ${2:expr}"],
    "description": "lambda statement"
  },
  "Function": {
    "prefix": "def",
    "body": ["def ${1:name}($2):", "\t${3:pass}"],
    "description": "Function definition"
  },
  "class": {
    "prefix": "class",
    "body": ["class ${1:classname}:", "\t${2:pass}"],
    "description": "Class definition"
  },
  "try/except/else/finally": {
    "prefix": "try",
    "body": [
      "try:",
      "\t${1:pass}",
      "except Exception as e:",
      "\t${2:print(f\"An exception occurred: {e\\}\")}",
      "else:",
      "\t${3:pass}",
      "finally:",
      "\t${4:pass}"
    ],
    "description": "try/except/else/finally blocks"
  }
}
